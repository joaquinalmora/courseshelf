{
  "name": "courseshelf",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
